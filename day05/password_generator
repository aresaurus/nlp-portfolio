import random
import string

letters = list(string.ascii_letters)
numbers = list(string.digits)
symbols = ['!', '#', '$', '%', '&', '(', ')', '*', '+']


print("Welcome to the PyPassword Generator!")
nr_letters = int(input("How many letters would you like in your password?\n"))
nr_symbols = int(input(f"How many symbols would you like?\n"))
nr_numbers = int(input(f"How many numbers would you like?\n"))


## Ordered password (letters, then symbols, then numbers)
user_password = ''
for letter in range(nr_letters):
    user_password += random.choice(letters)
for symbol in range(nr_symbols):
    user_password += random.choice(symbols)
for number in range(nr_numbers):
    user_password += random.choice(numbers)
print(user_password)

## Shuffled version
shuffled_chars = random.sample(user_password, len(user_password))
print(''.join(shuffled_chars))